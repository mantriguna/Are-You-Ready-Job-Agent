META_ACCESS_TOKEN=replace_with_your_meta_system_user_token
META_PHONE_NUMBER_ID=replace_with_your_whatsapp_phone_number_id
META_WABA_ID=replace_with_your_whatsapp_business_account_id
META_VERIFY_TOKEN=replace_with_your_meta_webhook_verify_token
META_GRAPH_API_VERSION=v25.0

SUPABASE_URL=replace_with_your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=replace_with_your_supabase_legacy_service_role_key
# Newer Supabase clients can also use:
# SUPABASE_SECRET_KEY=replace_with_your_supabase_server_secret_key

GEMINI_API_KEY=replace_with_your_google_ai_studio_api_key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODEL=gemini-2.5-flash-lite

# Comma-separated public ATS board identifiers.
# Examples are company-specific; choose boards you actually want to monitor.
GREENHOUSE_BOARD_TOKENS=
LEVER_COMPANY_SLUGS=
ASHBY_BOARD_NAMES=
ENABLE_AMAZON_JOBS=true
PUBLIC_BASE_URL=https://your-render-or-localtunnel-url
PREFERRED_JOB_QUERIES=SDE-1,Software Development Engineer,Backend Engineer

APP_TIMEZONE=Asia/Kolkata
CRON_SECRET=replace_with_a_long_random_secret
SCHEDULER_MAX_CONCURRENCY=3
