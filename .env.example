APP_TIMEZONE=Asia/Kolkata
PUBLIC_BASE_URL=https://are-you-ready-job-agent.onrender.com

META_ACCESS_TOKEN=replace_with_meta_access_token
META_PHONE_NUMBER_ID=replace_with_meta_phone_number_id
META_WABA_ID=replace_with_meta_waba_id
META_VERIFY_TOKEN=replace_with_meta_verify_token
META_GRAPH_API_VERSION=v25.0

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace_with_supabase_service_role_key

GEMINI_API_KEY=replace_with_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODEL=gemini-2.5-flash-lite
USE_LLM_MATCHING=false
ENABLE_HEURISTIC_AI_FALLBACK=true

CRON_SECRET=replace_with_cron_secret
USE_WHATSAPP_TEMPLATES=true
WHATSAPP_JOB_TEMPLATE_NAME=job_match_alert
WHATSAPP_DAILY_SUMMARY_TEMPLATE_NAME=daily_job_summary
WHATSAPP_NO_MATCH_TEMPLATE_NAME=daily_no_match
WHATSAPP_TEMPLATE_LANGUAGE=en_US

MIN_MATCH_SCORE=75
MAX_MATCHED_JOBS_PER_USER=0
MAX_EVALUATIONS_PER_RUN=0
JOB_EVALUATION_POOL_LIMIT=0
MAX_PAGES_PER_SOURCE=0
JOB_SOURCE_CONCURRENCY=5
HTTP_TIMEOUT_SECONDS=30
HTTP_MAX_RESPONSE_CHARS=2000000
ENABLE_OFFICIAL_COMPANY_SOURCES=true
ALLOW_BELOW_THRESHOLD_FILL=false
SEND_ALL_ABOVE_THRESHOLD_MATCHES=true
SENT_JOB_RETENTION_DAYS=60

RAPIDAPI_KEY=
RAPIDAPI_JOBS_HOST=jsearch.p.rapidapi.com
ENABLE_AMAZON_JOBS=true
GREENHOUSE_BOARD_TOKENS=
LEVER_COMPANY_SLUGS=
ASHBY_BOARD_NAMES=
PREFERRED_JOB_QUERIES=SDE-1,Software Development Engineer,Backend Engineer,Python Developer,Java Developer
OFFICIAL_COMPANY_SEARCH_QUERY=software engineer
